{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Watchlist": {
      "title": "Watchlist",
      "description": "User's favorite crypto symbols",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID who owns this watchlist" },
        "symbols": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of crypto symbols (e.g., BTCUSDT)" 
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "symbols", "updatedAt"]
    },
    "Trade": {
      "title": "Trade",
      "description": "Executed trade record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID who executed the trade" },
        "symbol": { "type": "string", "description": "Crypto symbol (e.g., BTCUSDT)" },
        "side": { "type": "string", "enum": ["buy", "sell"], "description": "Trade side" },
        "type": { "type": "string", "enum": ["limit", "market"], "description": "Order type" },
        "price": { "type": "number", "description": "Execution price" },
        "amount": { "type": "number", "description": "Amount traded" },
        "total": { "type": "number", "description": "Total value in USDT" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Execution timestamp" }
      },
      "required": ["uid", "symbol", "side", "type", "price", "amount", "total", "timestamp"]
    },
    "Signal": {
      "title": "Signal",
      "description": "Trading signal",
      "type": "object",
      "properties": {
        "activo": { "type": "string", "description": "Symbol (e.g., BTCUSDT)" },
        "tipo": { "type": "string", "enum": ["LONG", "SHORT"], "description": "Signal type" },
        "entry": { "type": "number", "description": "Entry price" },
        "tp1": { "type": "number", "description": "Take profit 1" },
        "tp2": { "type": "number", "description": "Take profit 2" },
        "tp3": { "type": "number", "description": "Take profit 3" },
        "sl": { "type": "number", "description": "Stop loss" },
        "estado": { "type": "string", "enum": ["activa", "cerrada"], "description": "Signal status" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "authorUid": { "type": "string", "description": "UID of the user who created the signal" }
      },
      "required": ["activo", "tipo", "entry", "tp1", "sl", "estado", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/watchlists/{userId}": {
      "schema": "Watchlist",
      "description": "User's individual watchlist"
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Global trade history (filtered by uid in rules)"
    },
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Global trading signals"
    }
  }
}
